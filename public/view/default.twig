<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8"/>
		<meta http-equiv="X-UA-Compatible" content="IE=edge"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
		<meta name="description" content="Sword">
		<link rel="icon" type="image/png" sizes="32x32" href="{{ path }}public/images/favicon.png"/>

		<meta property="og:title" content="Sword">
		<meta property="og:description" content="Cliqueur game">

		<title>{% block title %}Sword{% endblock %}</title>
		<!-- FontAwesome pour les icônes -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
		<!-- own CSS-->
		<link rel="stylesheet" href="{{ path }}public/css/styles.css"/>

		{% block stylesheet %}{% endblock %}
	</head>
	<body>
		{% if isLogged %}
			{% include 'rss.twig' %}
		{% endif %}
			<div id="toast-container"></div>
			<div class="container">
				{% block content %}
				<div class="container"></div>
				<!-- Le contenu de la page sera ici -->
				{% endblock %}
			</div>

		<footer class="footer">
		<!-- jQuery -->
		<script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
		
		<!-- Popper.js -->
		<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
		<!-- Bootstrap JS -->
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
		<!-- config JS -->
		<script src="{{ path }}public/js/config.js"></script>
		<!-- app JS -->
		<script type ="module" src="{{ path }}public/js/app.js" defer ></script>
		<!-- utils JS-->
		<script type="module" src="{{ path }}public/js/utils.js"></script>
		<!-- auth JS-->
		<script type="module" src="{{ path }}public/js/auth/auth.js"></script>
		{% if isLogged %}
		<!-- rss JS-->
		<script type="module" src="{{ path }}public/js/rssBar/rss.js"></script>
		<!-- save JS-->
		<script type="module" src="{{ path }}public/js/save/save.js"></script>
		<!-- zones JS-->
		<script type="module" src="{{ path }}public/js/zones/zones.js"></script>
		<!-- boss JS-->
		<script type="module" src="{{ path }}public/js/boss/boss.js"></script>
		<!-- sword JS-->
		<script type="module" src="{{ path }}public/js/sword/sword.js"></script>
		{% endif %}
		</footer>
		{% block javascript %}{% endblock %}
	</body>
</html>